# Application
NEXT_PUBLIC_APP_NAME="万卷书苑"
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=2h
REFRESH_TOKEN_EXPIRES_IN=30d

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/10kbooks

# Redis
REDIS_URL=redis://localhost:6379

# AWS S3 / Aliyun OSS
AWS_REGION=ap-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=10kbooks-uploads

ALIYUN_ACCESS_KEY=your-access-key
ALIYUN_SECRET_KEY=your-secret-key
ALIYUN_BUCKET=10kbooks-oss
ALIYUN_REGION=oss-cn-hangzhou

# AI Services
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# Payment
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

# Alipay
ALIPAY_APP_ID=your-app-id
ALIPAY_PRIVATE_KEY=your-private-key
ALIPAY_PUBLIC_KEY=alipay-public-key

# WeChat Pay
WECHAT_APP_ID=your-app-id
WECHAT_MCH_ID=your-mch-id
WECHAT_API_KEY=your-api-key

# Feature Flags
ENABLE_AI_FEATURES=true
ENABLE_PAYMENT=true
ENABLE_MULTI_LANGUAGE=true

# Email (for sending verification codes)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@10kbooks.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM="万卷书苑 <noreply@10kbooks.com>"

# SMS (for verification codes)
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY=your-access-key
SMS_ACCESS_SECRET=your-secret-secret
